<%# Item Edit Form - SimpleForm with brand styling %>
<div class="bg-white shadow-sm rounded border border-gray-100 p-6">
  <%= simple_form_for item, url: local_assigns[:url], html: { class: "space-y-6" } do |f| %>
    <%# Item Name %>
    <div>
      <%= f.input :name,
          label: "Item Name",
          input_html: {
            placeholder: "Enter item name"
          },
          hint: "The name of this expense, income, or savings item" %>
    </div>

    <%# Item Description %>
    <div>
      <%= f.input :description,
          label: "Description (Optional)",
          input_html: {
            rows: 3,
            placeholder: "Add any additional details about this item"
          },
          hint: "Optional description to help identify this item" %>
    </div>

    <%# Category (Read-only for editing) %>
    <div>
      <label class="form-label">Category</label>
      <div class="form-input flex items-center bg-gray-50">
        <%= item.category.name %>
      </div>
      <p class="form-hint">Use Manage Items to move between categories</p>
      <%= f.hidden_field :category_id %>
    </div>

    <% if @previous_url.present? %>
      <%= hidden_field_tag :previous_url, @previous_url %>
    <% end %>

    <%# Form Actions %>
    <div class="flex flex-col sm:flex-row sm:justify-end gap-3 pt-6 border-t border-gray-200">
      <%= link_to "Cancel",
@previous_url.presence || category_path(item.category),
          class: "btn btn-secondary" %>

      <%= f.submit item.persisted? ? "Update Item" : "Create Item",
          class: "btn btn-primary" %>
    </div>
    
  <% end %>
</div> 