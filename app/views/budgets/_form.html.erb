<%# Budget Form Partial - matches Categories design patterns %>
<%= page_header(
    title: @budget.persisted? ? "Edit Budget" : "New Budget",
    subtitle: @budget.category ? "Set spending limits for #{@budget.category.name}" : "Set spending limits for this category"
) %>

<div class="max-w-2xl mx-auto">
  <%= simple_form_for @budget, html: { class: "space-y-6" } do |f| %>
    <%# Main Form Card %>
    <div class="bg-white shadow-sm rounded border border-gray-100 p-6">
      <div class="space-y-6">
        <%# Category Selection (only for new budgets without category_id) %>
        <% unless @budget.category_id %>
          <div>
            <%= f.association :category,
                collection: current_user.categories.expenses.budgetable.order(:name),
                label_method: :name,
                value_method: :id,
                include_blank: "Select an expense category",
                label: "Category" %>
          </div>
        <% else %>
          <%# Show category name for existing budgets %>
          <div>
            <label class="form-label">Category</label>
            <div class="form-input flex items-center bg-gray-50">
              <%= @budget.category.name %>
            </div>
            <%= f.hidden_field :category_id %>
          </div>
        <% end %>

        <%# Budget Amount %>
        <div>
          <%= f.input :amount,
              as: :decimal,
              label: "Budget Amount",
              input_html: {
                placeholder: "0.00",
                step: 0.01,
                min: 0
              },
              hint: "Enter the maximum amount you want to spend in this category" %>
        </div>

        <%# Prorated toggle %>
        <div>
          <div class="flex items-center gap-2 mb-2">
            <%= f.check_box :prorated, class: "form-checkbox" %>
            <%= f.label :prorated, "Prorate daily", class: "form-label mb-0 cursor-pointer" %>
          </div>
          <p class="form-hint">
            Spread the budget evenly across the month so you can see if you're on pace day-to-day. Turn off for expenses that happen in one-time chunks (like rent or subscriptions).
          </p>
        </div>

      </div>
    </div>

    <%# Action Buttons %>
    <div class="flex flex-col sm:flex-row sm:justify-end gap-3">
      <%= link_to "Cancel",
          @budget.category ? category_path(@budget.category) : categories_path,
          class: "btn btn-secondary" %>

      <%= f.submit @budget.persisted? ? "Update Budget" : "Create Budget",
          class: "btn btn-primary" %>
    </div>
  <% end %>
</div> 