<% content_for :title, "Merge into #{@target.name}" %>

<%= page_header(
    title: "Merge into #{@target.name}",
    subtitle: "Select items to merge &mdash; their entries will be transferred to <strong>#{@target.name}</strong>".html_safe,
    breadcrumbs: [
      { label: "Categories", url: categories_path(type: @category.category_type) },
      { label: @category.name, url: category_path(@category) },
      { label: "Manage Items", url: category_items_path(@category) },
      { label: "Merge" }
    ]
) %>

<% if @other_items.any? %>
  <div class="container mx-auto px-4" data-controller="app--item--merge">
    <%= form_with url: merge_category_items_path(@category), method: :post, local: true do |f| %>
      <%= hidden_field_tag :target_item_id, @target.id %>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
        <%# Left: Item Picker %>
        <div class="lg:col-span-3">
          <div class="bg-white shadow-sm rounded border border-gray-100 p-6">
            <div class="relative mb-4">
              <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                <%= heroicon "magnifying-glass", options: { class: "h-4 w-4 text-gray-400" } %>
              </div>
              <input type="text" placeholder="Filter items..."
                     class="pl-10 py-2 pr-3 block w-full rounded border-gray-300 shadow-sm focus:border-brand focus:ring-brand focus:ring-1 sm:text-sm"
                     data-app--item--merge-target="filterInput"
                     data-action="input->app--item--merge#filter"
                     autocomplete="off"
                     autofocus>
            </div>

            <div class="space-y-2 max-h-[32rem] overflow-y-auto">
              <% @other_items.each do |item| %>
                <label class="flex items-center p-3 border rounded cursor-pointer hover:border-brand hover:bg-gray-50 transition-colors
                              has-[:checked]:border-brand has-[:checked]:bg-brand/5"
                       data-app--item--merge-target="item"
                       data-filter-name="<%= item.name.downcase %>"
                       data-item-name="<%= item.name %>"
                       data-item-entries="<%= item.entries.size %>"
                       data-item-amount="<%= number_to_currency(item.entries.map(&:amount).sum) %>">
                  <input type="checkbox" name="source_item_ids[]" value="<%= item.id %>"
                         class="h-4 w-4 rounded border-gray-300 text-brand focus:ring-brand mr-3"
                         data-action="change->app--item--merge#selectionChanged">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                      <span class="font-medium text-gray-900 text-sm"><%= item.name %></span>
                      <span class="text-sm font-medium text-gray-900">
                        <%= number_to_currency(item.entries.map(&:amount).sum) %>
                      </span>
                    </div>
                    <div class="flex items-center gap-3 mt-0.5 text-xs text-gray-500">
                      <span><%= item.entries.size %> entries</span>
                      <span>Last active: <%= time_ago_in_words(item.updated_at) %> ago</span>
                    </div>
                  </div>
                </label>
              <% end %>
            </div>
          </div>
        </div>

        <%# Right: Merge Summary (sticky on desktop) %>
        <div class="lg:col-span-2">
          <div class="lg:sticky lg:top-6">
            <div class="bg-white shadow-sm rounded border border-gray-100 p-6">
              <h2 class="text-base font-semibold text-gray-900 mb-4">Merging into <%= @target.name %></h2>

              <p data-app--item--merge-target="emptyMessage" class="text-sm text-gray-500 mb-4">
                Select items from the list to merge.
              </p>

              <div data-app--item--merge-target="selectedList" class="hidden mb-4">
                <div class="divide-y divide-gray-100 max-h-64 overflow-y-auto" data-app--item--merge-target="selectedItems"></div>
                <div class="mt-3 p-3 bg-status-warning-light rounded border border-status-warning">
                  <p class="text-sm text-status-warning">
                    <%= heroicon "exclamation-triangle", options: { class: "h-4 w-4 inline-block mr-1" } %>
                    These items will be deleted. Entries transfer to <strong><%= @target.name %></strong>.
                  </p>
                </div>
              </div>

              <div class="flex flex-col gap-2">
                <%= f.submit "Merge Items",
                    class: "w-full inline-flex items-center justify-center gap-2 px-4 py-2 rounded bg-brand text-white text-sm font-medium hover:bg-brand-dark shadow-sm transition cursor-pointer disabled:opacity-50",
                    disabled: true,
                    data: { "app--item--merge-target": "submitButton" } %>
                <%= link_to "Cancel", category_items_path(@category),
                    class: "w-full inline-flex items-center justify-center gap-2 px-4 py-2 rounded border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 shadow-sm transition text-center" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="max-w-2xl mx-auto">
    <div class="bg-white shadow-sm rounded border border-gray-100 p-12 text-center">
      <p class="text-sm text-gray-500 mb-4">No other items available to merge.</p>
      <%= link_to "Back to Manage Items", category_items_path(@category),
          class: "inline-flex items-center gap-2 px-4 py-2 rounded border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 shadow-sm transition" %>
    </div>
  </div>
<% end %>
