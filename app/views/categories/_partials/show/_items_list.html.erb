<!-- Items List -->
<div class="bg-white shadow-sm rounded border border-gray-100">
  <div class="flex justify-between items-center p-6 pb-4">
    <h2 class="text-xl font-semibold"><%= period_items_label %></h2>
  </div>

  <% current_month_items = category.calculator(selected_date, period: current_period).current_month_items %>
  <% amount_color_class = category.expense? ? "text-status-danger" : (category.income? ? "text-status-success" : "text-brand") %>
  <% amount_prefix = category.expense? ? "-" : "+" %>

  <% if current_month_items.any? %>
    <% items_collection = current_month_items.map { |item, data| { item: item, data: data } } %>

    <%# Mobile: Card Layout %>
    <div class="md:hidden divide-y divide-gray-200 border-t border-gray-100">
      <%= render partial: "categories/_partials/show/item_card",
                 collection: items_collection,
                 locals: { amount_color_class: amount_color_class, amount_prefix: amount_prefix } %>
    </div>

    <%# Desktop: Table Layout %>
    <div class="hidden md:block overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Name</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Frequency</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Last Date</th>
            <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Entries</th>
            <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Total Amount</th>
            <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
              <span class="sr-only">Actions</span>
            </th>
          </tr>
        </thead>
        <%= render partial: "categories/_partials/show/item_row",
                   collection: items_collection,
                   locals: { amount_color_class: amount_color_class, amount_prefix: amount_prefix } %>
      </table>
    </div>
  <% else %>
    <div class="bg-gray-50 rounded m-6 mt-0 p-6 text-center">
      <div class="mx-auto w-12 h-12 rounded-full bg-gray-200 flex items-center justify-center mb-3">
        <%= heroicon "inbox", options: { class: "h-6 w-6 text-gray-400" } %>
      </div>
      <h3 class="text-base font-medium text-gray-900 mb-1">No items for <%= period_time_label %></h3>
      <p class="text-sm text-gray-500 mb-4">Items will appear here when you add entries for <%= period_time_label %></p>
    </div>
  <% end %>
</div>
