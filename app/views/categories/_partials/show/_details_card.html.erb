<!-- Category Details -->
<div class="bg-white shadow-sm rounded overflow-hidden border border-gray-100 p-6">
  <h2 class="text-xl font-semibold mb-4">Details</h2>
  
  <dl class="divide-y divide-gray-200">
    <div class="py-3 flex justify-between">
      <dt class="text-sm font-medium text-gray-500">Category Type</dt>
      <dd class="text-sm text-gray-900"><%= category.category_type.capitalize %></dd>
    </div>
    
    <div class="py-3 flex justify-between">
      <dt class="text-sm font-medium text-gray-500">Color</dt>
      <dd class="text-sm text-gray-900 flex items-center">
        <span class="w-4 h-4 rounded mr-2" style="background-color: <%= category.color || "#C9C78B" %>;"></span>
        <%= category.color || "Default" %>
      </dd>
    </div>
    
    <div class="py-3 flex justify-between items-center">
      <dt class="text-sm font-medium text-gray-500">Tracked</dt>
      <dd>
        <%= button_to toggle_tracked_category_path(category),
            method: :patch,
            data: { controller: "shared--toggle", action: "click->shared--toggle#toggle", shared__toggle_on_value: "translate-x-6", shared__toggle_off_value: "translate-x-1" },
            class: "relative inline-flex h-6 w-11 items-center rounded-full transition-colors #{category.tracked? ? "bg-brand" : "bg-gray-300"}" do %>
          <span data-shared--toggle-target="thumb" class="inline-block h-4 w-4 rounded-full bg-white transition-transform <%= category.tracked? ? "translate-x-6" : "translate-x-1" %>"></span>
        <% end %>
      </dd>
    </div>

    <div class="py-3 flex justify-between">
      <dt class="text-sm font-medium text-gray-500">Number of Items</dt>
      <dd class="text-sm text-gray-900"><%= category.items.count %></dd>
    </div>
    
    <div class="py-3 flex justify-between">
      <dt class="text-sm font-medium text-gray-500">Total Entries</dt>
      <dd class="text-sm text-gray-900"><%= category.entries.count %></dd>
    </div>
    
    <div class="py-3 flex justify-between">
      <dt class="text-sm font-medium text-gray-500">Created</dt>
      <dd class="text-sm text-gray-900"><%= category.created_at.strftime("%b %d, %Y") %></dd>
    </div>
  </dl>
</div> 