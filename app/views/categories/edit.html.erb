<% content_for :title, "Edit #{@category.name}" %>

<%= page_header(
    title: "Edit #{@category.name}",
    subtitle: "Update your category details",
    breadcrumbs: [
      { label: "Categories", url: categories_path },
      { label: @category.name, url: category_path(@category) },
      { label: "Edit" }
    ]
) %>

<div class="max-w-3xl mx-auto">
  <%= render "form", category: @category %>
</div>
