<%# Mobile Entry Card %>
<div class="p-4 hover:bg-gray-50 transition-colors">
  <%# Header: Type badge + Amount %>
  <div class="flex items-center justify-between mb-3">
    <%= entry_type_badge(entry_card.item.category.category_type) %>
    <span class="text-base font-semibold text-gray-900"><%= number_to_currency(entry_card.amount) %></span>
  </div>

  <%# Main content %>
  <div class="flex justify-between items-start">
    <div class="flex-1 min-w-0 pr-4">
      <div class="font-medium text-gray-900 truncate"><%= entry_card.item.name %></div>
      <div class="flex items-center gap-2 mt-1 text-sm text-gray-500">
        <% category = entry_card.item.category %>
        <%= link_to category.name, category_path(category), class: "hover:text-brand transition-colors" %>
        <span class="text-gray-300">|</span>
        <span><%= entry_card.date.strftime("%b %d") %></span>
      </div>
      <% if entry_card.description.present? %>
        <p class="text-sm text-gray-400 mt-1 line-clamp-1"><%= entry_card.description %></p>
      <% end %>
    </div>

    <%# Actions %>
    <div class="flex items-center gap-1">
      <%= link_to edit_entry_path(entry_card),
                  class: "p-2 text-gray-400 hover:text-status-info hover:bg-gray-100 rounded transition-colors",
                  title: "Edit" do %>
        <%= heroicon "pencil", options: { class: "w-4 h-4" } %>
      <% end %>
      <%= link_to entry_path(entry_card),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this entry?" },
                  class: "p-2 text-gray-400 hover:text-status-danger hover:bg-gray-100 rounded transition-colors",
                  title: "Delete" do %>
        <%= heroicon "trash", options: { class: "w-4 h-4" } %>
      <% end %>
    </div>
  </div>
</div>
