<% return unless entries.respond_to?(:current_page) %>

<% if entries.total_pages > 1 %>
  <div class="bg-white px-6 py-4 border-t border-gray-200">
    <%# Mobile pagination %>
    <% pagination_btn = "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded hover:bg-gray-50 transition-colors shadow-sm" %>
    <div class="flex justify-between items-center md:hidden">
      <%= link_to_prev_page entries, "Previous", class: pagination_btn %>
      <span class="text-sm font-semibold text-gray-900">Page <%= entries.current_page %> of <%= entries.total_pages %></span>
      <%= link_to_next_page entries, "Next", class: pagination_btn %>
    </div>

    <%# Desktop pagination %>
    <div class="hidden md:flex md:items-center md:justify-between">
      <p class="text-sm text-gray-700">
        Showing <span class="font-semibold text-gray-900"><%= entries.offset_value + 1 %></span> to
        <span class="font-semibold text-gray-900"><%= entries.offset_value + entries.length %></span> of
        <span class="font-semibold text-gray-900"><%= entries.total_count %></span> entries
      </p>
      <nav class="inline-flex rounded shadow-sm -space-x-px" aria-label="Pagination">
        <%= paginate entries %>
      </nav>
    </div>
  </div>
<% elsif entries.total_count.positive? %>
  <div class="bg-white px-4 py-3 border-t border-gray-200 sm:px-6">
    <p class="text-sm text-gray-700 text-center">
      <span class="font-medium"><%= entries.total_count %></span>
      <%= entries.total_count == 1 ? "entry" : "entries" %> total
    </p>
  </div>
<% end %>
