<div class="min-h-screen bg-gray-50 relative">
  <div class="absolute top-0 left-0 right-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <%= link_to root_path, class: "inline-flex items-center py-4 text-gray-600 hover:text-brand-dark transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to Home
      <% end %>
    </div>
  </div>

  <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full bg-white rounded shadow-sm p-8 space-y-8">
      <% if flash[:alert] %>
        <div class="rounded bg-status-danger-light p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-status-danger" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-status-danger"><%= flash[:alert] %></p>
            </div>
          </div>
        </div>
      <% end %>

      <div>
        <h2 class="text-center text-3xl font-bold text-sage-600">
          Create your account
        </h2>
        <p class="mt-2 text-center text-sm text-gray-600">
          Start managing your finances today
        </p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-8 space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div style="position: absolute; left: -9999px;" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" name="website" id="website" tabindex="-1" autocomplete="off">
        </div>

        <%# Auto-detect the new user's timezone from the browser. Falls back to
            blank (normalized to nil → UTC) if JavaScript is unavailable. %>
        <%= f.hidden_field :timezone %>
        <script>
          (function () {
            var field = document.getElementById("user_timezone");
            if (!field) return;
            try {
              field.value = Intl.DateTimeFormat().resolvedOptions().timeZone || "";
            } catch (e) { /* leave blank; server falls back to UTC */ }
          })();
        </script>

        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "form-label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
          </div>

          <div>
            <%= f.label :password, class: "form-label" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-input" %>
            <% if @minimum_password_length %>
              <p class="form-hint">Minimum <%= @minimum_password_length %> characters</p>
            <% end %>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "form-label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
          </div>
        </div>

        <%= f.submit "Sign up", class: "w-full btn btn-primary-light" %>
      <% end %>

      <div class="text-center text-sm">
        <%= link_to "Already have an account? Sign in", new_session_path(resource_name), class: "text-sage-700 hover:text-sage-800 transition-colors" %>
      </div>
    </div>
  </div>
</div>
