<%= render layout: "devise/shared/auth_card",
    locals: {
      title: "Forgot your password?",
      subtitle: "We'll email you instructions to reset it",
      footer: render("devise/shared/links")
    } do %>
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
    </div>

    <%= f.submit "Send reset instructions", class: "w-full btn btn-primary-light" %>
  <% end %>
<% end %>
