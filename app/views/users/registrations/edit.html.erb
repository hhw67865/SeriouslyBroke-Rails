<% content_for :title, "Edit Account" %>

<%= page_header(
    title: "Edit Account",
    subtitle: "Update your name, email, or password",
    breadcrumbs: [
      { label: "Account", url: account_path },
      { label: "Edit" }
    ]
) %>

<div class="max-w-2xl mx-auto">
  <div class="bg-white shadow-sm rounded border border-gray-100 p-6">
    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
      <%= f.error_notification %>
      <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

      <div>
        <%= f.input :name,
            label_html: { class: "block text-sm font-medium text-gray-700 mb-2" },
            input_html: {
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-brand focus:ring-brand focus:ring-1 sm:text-sm",
              autocomplete: "name"
            } %>
      </div>

      <div>
        <%= f.input :email,
            label_html: { class: "block text-sm font-medium text-gray-700 mb-2" },
            input_html: {
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-brand focus:ring-brand focus:ring-1 sm:text-sm",
              autocomplete: "email"
            } %>
      </div>

      <div>
        <%= f.input :email_confirmation,
            label: "Confirm email",
            required: false,
            hint: "Required only when changing your email",
            label_html: { class: "block text-sm font-medium text-gray-700 mb-2" },
            input_html: {
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-brand focus:ring-brand focus:ring-1 sm:text-sm",
              autocomplete: "off"
            } %>
      </div>

      <div>
        <%= f.input :password,
            label: "New password",
            required: false,
            hint: "Leave blank to keep your current password",
            label_html: { class: "block text-sm font-medium text-gray-700 mb-2" },
            input_html: {
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-brand focus:ring-brand focus:ring-1 sm:text-sm",
              autocomplete: "new-password"
            } %>
      </div>

      <div>
        <%= f.input :password_confirmation,
            label: "Confirm new password",
            required: false,
            label_html: { class: "block text-sm font-medium text-gray-700 mb-2" },
            input_html: {
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-brand focus:ring-brand focus:ring-1 sm:text-sm",
              autocomplete: "new-password"
            } %>
      </div>

      <div>
        <%= f.input :current_password,
            label: "Current password",
            required: false,
            hint: "Required to change email or password",
            label_html: { class: "block text-sm font-medium text-gray-700 mb-2" },
            input_html: {
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-brand focus:ring-brand focus:ring-1 sm:text-sm",
              autocomplete: "current-password"
            } %>
      </div>

      <div class="flex flex-col sm:flex-row sm:justify-end gap-3 pt-6 border-t border-gray-200">
        <%= link_to "Cancel",
            account_path,
            class: "inline-flex items-center justify-center gap-2 px-4 py-2 rounded border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 shadow-sm transition" %>

        <%= f.submit "Save Changes",
            class: "inline-flex items-center justify-center gap-2 px-4 py-2 rounded bg-brand text-white text-sm font-medium hover:bg-brand-dark shadow-sm transition" %>
      </div>
    <% end %>
  </div>
</div>
