<% cache [current_user, selected_date, current_period, :all_v9] do %>
<% income = @presenter.total_tracked_income %>
<% expenses = @presenter.total_tracked_expenses %>
<% budgetable = @presenter.total_tracked_budgetable_expenses %>
<% contributions = @presenter.savings_contributions_total %>
<% withdrawals = @presenter.savings_withdrawals_total %>
<% remaining = @presenter.income_remaining %>

<%# Money Flow — Income Allocation (where income went) + Expense Sources (where expenses came from) %>
<div class="mb-8">
  <h3 class="text-lg font-medium text-gray-900 mb-4">Money Flow</h3>

  <%# Bar 1 — Income Allocation %>
  <div class="bg-gray-50 rounded p-4 mb-4">
    <h4 class="text-sm font-medium text-gray-700 mb-3">Income Allocation</h4>
    <% if income.positive? %>
      <% denom = [income, budgetable + contributions].max.to_f %>
      <% budgetable_pct = denom.positive? ? (budgetable / denom * 100).round(1) : 0 %>
      <% contributions_pct = denom.positive? ? (contributions / denom * 100).round(1) : 0 %>
      <% remaining_pct = [100 - budgetable_pct - contributions_pct, 0].max.round(1) %>
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-medium text-gray-900"><%= number_to_currency(income) %> earned</span>
        <span class="text-sm font-medium <%= remaining >= 0 ? "text-brand-dark" : "text-terracotta" %>"><%= number_to_currency(remaining) %> remaining</span>
      </div>
      <div class="flex w-full h-8 rounded overflow-hidden">
        <% if budgetable_pct.positive? %>
          <div class="bg-terracotta flex items-center justify-center" style="width: <%= budgetable_pct %>%">
            <% if budgetable_pct > 10 %>
              <span class="text-xs font-medium text-white"><%= budgetable_pct %>%</span>
            <% end %>
          </div>
        <% end %>
        <% if contributions_pct.positive? %>
          <div class="bg-dusty-teal flex items-center justify-center" style="width: <%= contributions_pct %>%">
            <% if contributions_pct > 10 %>
              <span class="text-xs font-medium text-white"><%= contributions_pct %>%</span>
            <% end %>
          </div>
        <% end %>
        <% if remaining_pct.positive? %>
          <div class="bg-brand flex items-center justify-center" style="width: <%= remaining_pct %>%">
            <% if remaining_pct > 10 %>
              <span class="text-xs font-medium text-white"><%= remaining_pct %>%</span>
            <% end %>
          </div>
        <% end %>
      </div>
      <div class="flex flex-wrap gap-4 mt-3 text-xs">
        <div class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-sm bg-terracotta"></span>
          <span class="text-gray-600">Budgeted <%= number_to_currency(budgetable) %></span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-sm bg-dusty-teal"></span>
          <span class="text-gray-600">Savings Contrib <%= number_to_currency(contributions) %></span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-sm bg-brand"></span>
          <span class="text-gray-600">Remaining <%= number_to_currency([remaining, 0].max) %></span>
        </div>
      </div>
    <% elsif expenses.positive? || contributions.positive? %>
      <p class="text-sm text-gray-500 mb-2">No income recorded <%= period_time_label %></p>
      <p class="text-sm text-gray-700">Expenses: <%= number_to_currency(expenses) %> · Contributions: <%= number_to_currency(contributions) %></p>
    <% else %>
      <p class="text-gray-500 text-center py-4">No data available <%= period_time_label %></p>
    <% end %>
  </div>

  <%# Bar 2 — Expense Sources (only when savings withdrawals exist) %>
  <% if withdrawals.positive? && expenses.positive? %>
    <% from_income_pct = (budgetable / expenses.to_f * 100).round(1) %>
    <% from_savings_pct = (withdrawals / expenses.to_f * 100).round(1) %>
    <div class="bg-gray-50 rounded p-4">
      <h4 class="text-sm font-medium text-gray-700 mb-3">Expense Sources</h4>
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-medium text-gray-900"><%= number_to_currency(expenses) %> spent</span>
        <span class="text-sm font-medium text-gray-700"><%= number_to_currency(withdrawals) %> came from savings</span>
      </div>
      <div class="flex w-full h-8 rounded overflow-hidden">
        <% if from_income_pct.positive? %>
          <div class="bg-terracotta flex items-center justify-center" style="width: <%= from_income_pct %>%">
            <% if from_income_pct > 10 %>
              <span class="text-xs font-medium text-white"><%= from_income_pct %>%</span>
            <% end %>
          </div>
        <% end %>
        <% if from_savings_pct.positive? %>
          <div class="bg-dusty-teal flex items-center justify-center" style="width: <%= from_savings_pct %>%">
            <% if from_savings_pct > 10 %>
              <span class="text-xs font-medium text-white"><%= from_savings_pct %>%</span>
            <% end %>
          </div>
        <% end %>
      </div>
      <div class="flex flex-wrap gap-4 mt-3 text-xs">
        <div class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-sm bg-terracotta"></span>
          <span class="text-gray-600">From Income <%= number_to_currency(budgetable) %></span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-sm bg-dusty-teal"></span>
          <span class="text-gray-600">From Savings <%= number_to_currency(withdrawals) %></span>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%# Health Indicators %>
<div class="grid grid-cols-1 md:grid-cols-<%= @presenter.total_budget.positive? ? 3 : 2 %> gap-4 mb-8">
  <% if @presenter.total_budget.positive? %>
    <div class="bg-gray-50 rounded p-4">
      <p class="text-sm text-gray-500"><%= period_budget_label %></p>
      <p class="text-2xl font-semibold <%= @presenter.budget_used_percentage > 100 ? "text-terracotta" : "text-brand-dark" %>">
        <%= @presenter.budget_used_percentage %>% used
      </p>
      <div class="w-full bg-gray-200 rounded-full h-2 mt-2">
        <div class="h-2 rounded-full <%= @presenter.budget_used_percentage > 100 ? "bg-terracotta" : "bg-brand" %>"
             style="width: <%= [@presenter.budget_used_percentage, 100].min %>%"></div>
      </div>
      <p class="text-xs text-gray-400 mt-1"><%= number_to_currency(@presenter.budgeted_total) %> of <%= number_to_currency(@presenter.total_budget) %></p>
    </div>
  <% end %>
  <% net_savings = @presenter.net_savings %>
  <div class="bg-gray-50 rounded p-4">
    <p class="text-sm text-gray-500">Net Savings</p>
    <p class="text-2xl font-semibold <%= net_savings >= 0 ? "text-brand-dark" : "text-terracotta" %>">
      <%= net_savings >= 0 ? "+" : "" %><%= number_to_currency(net_savings) %>
    </p>
    <p class="text-xs text-gray-400">contributions − withdrawals</p>
  </div>
  <div class="bg-gray-50 rounded p-4">
    <p class="text-sm text-gray-500">Expense Ratio</p>
    <p class="text-2xl font-semibold text-gray-700"><%= @presenter.expense_ratio %>%</p>
    <p class="text-xs text-gray-400">of income spent</p>
  </div>
</div>

<%# Savings Pools Progress %>
<%= render "dashboard/savings_pools_strip" %>

<%# Top Spending %>
<% top_categories = @presenter.top_expense_categories %>
<% if top_categories.any? %>
  <div class="mb-8">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Top Spending</h3>
    <div class="space-y-3">
      <% top_categories.each do |cat| %>
        <div class="flex items-center justify-between py-2 border-b border-gray-100">
          <div class="flex items-center gap-3">
            <%= link_to cat[:name], category_path(cat[:id]), class: "text-gray-700 hover:text-brand-dark" %>
            <% if expenses.positive? %>
              <span class="text-xs text-gray-400"><%= (cat[:amount] / expenses.to_f * 100).round %>%</span>
            <% end %>
          </div>
          <span class="font-medium text-gray-900"><%= number_to_currency(cat[:amount]) %></span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
<% end %>
