<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
  <div class="bg-gray-50 rounded p-4">
    <p class="text-sm text-gray-500"><%= @presenter.ytd? ? "YTD Contributed" : "Contributed" %></p>
    <p class="text-2xl font-semibold text-brand-dark"><%= number_to_currency(@presenter.total_tracked_savings_contribution) %></p>
  </div>
  <div class="bg-gray-50 rounded p-4">
    <p class="text-sm text-gray-500"><%= @presenter.ytd? ? "YTD Withdrawn" : "Withdrawn" %></p>
    <p class="text-2xl font-semibold text-gray-700"><%= number_to_currency(@presenter.total_withdrawals) %></p>
  </div>
  <div class="bg-gray-50 rounded p-4">
    <p class="text-sm text-gray-500">Savings Rate</p>
    <p class="text-2xl font-semibold text-brand-dark"><%= @presenter.savings_rate %>%</p>
    <p class="text-xs text-gray-400">of income</p>
  </div>
</div>
