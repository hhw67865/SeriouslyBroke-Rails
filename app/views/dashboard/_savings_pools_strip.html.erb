<% pools = @presenter.pools_summary %>
<% if pools.any? %>
  <div class="mb-8">
    <div class="mb-4">
      <h3 class="text-lg font-medium text-gray-900">Savings Pools</h3>
      <p class="text-sm text-gray-500">
        Total: <span class="font-semibold <%= @presenter.total_pools_balance >= 0 ? "text-brand-dark" : "text-terracotta" %>"><%= number_to_currency(@presenter.total_pools_balance) %></span>
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% pools.each do |pool| %>
        <% progress = pool[:progress_percentage] %>
        <% negative = pool[:balance].negative? %>

        <%# Status based purely on funding level %>
        <% if negative %>
          <% card_class = "border-2 border-status-danger/40 bg-status-danger-light" %>
          <% bar_class = "bg-status-danger" %>
          <% badge_class = "text-white bg-status-danger" %>
          <% badge_text = "negative" %>
        <% elsif progress < 10 && pool[:target_amount].positive? %>
          <% card_class = "border-2 border-status-warning/40 bg-status-warning-light" %>
          <% bar_class = "bg-status-warning" %>
          <% badge_class = "text-status-warning bg-status-warning/20" %>
          <% badge_text = "low" %>
        <% elsif progress >= 100 %>
          <% card_class = "border border-gray-100 bg-gray-50" %>
          <% bar_class = "bg-brand" %>
          <% badge_class = "text-brand-dark bg-brand/20" %>
          <% badge_text = "funded" %>
        <% elsif progress >= 50 %>
          <% card_class = "border border-gray-100 bg-gray-50" %>
          <% bar_class = "bg-brand" %>
          <% badge_class = "text-brand-dark bg-brand/20" %>
          <% badge_text = "#{progress}%" %>
        <% else %>
          <% card_class = "border border-gray-100 bg-gray-50" %>
          <% bar_class = "bg-brand" %>
          <% badge_class = "text-gray-500 bg-gray-200" %>
          <% badge_text = "#{progress}%" %>
        <% end %>

        <%= link_to savings_pool_path(pool[:id]),
            class: "block rounded p-4 hover:opacity-90 transition #{card_class}" do %>
          <div class="flex items-center justify-between mb-2">
            <p class="text-sm font-medium text-gray-900 truncate"><%= pool[:name] %></p>
            <span class="text-xs font-medium px-2 py-0.5 rounded shrink-0 <%= badge_class %>"><%= badge_text %></span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-3 mb-2">
            <div class="h-3 rounded-full <%= bar_class %>" style="width: <%= progress.clamp(0, 100) %>%"></div>
          </div>
          <div class="flex items-center justify-between text-xs text-gray-500 mb-3">
            <span class="font-medium"><%= number_to_currency(pool[:balance]) %></span>
            <span>of <%= number_to_currency(pool[:target_amount]) %></span>
          </div>
          <div class="flex items-center justify-between text-xs">
            <div>
              <span class="text-gray-400">In </span>
              <span class="font-medium text-brand-dark"><%= number_to_currency(pool[:period_contributions]) %></span>
            </div>
            <div>
              <span class="text-gray-400">Out </span>
              <span class="font-medium <%= pool[:period_withdrawals].positive? ? "text-status-danger" : "text-gray-700" %>"><%= number_to_currency(pool[:period_withdrawals]) %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
