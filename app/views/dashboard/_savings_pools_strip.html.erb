<% pools = @presenter.pools_summary %>
<% if pools.any? %>
  <div class="mb-8">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Savings Pools</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% pools.each do |pool| %>
        <%= link_to savings_pool_path(pool[:id]), class: "block bg-gray-50 rounded p-4 hover:bg-gray-100 transition" do %>
          <div class="flex items-center justify-between mb-1">
            <p class="text-sm font-medium text-gray-900 truncate"><%= pool[:name] %></p>
            <span class="text-xs font-medium text-gray-500"><%= pool[:progress_percentage] %>%</span>
          </div>
          <div class="flex items-center justify-between text-xs text-gray-400 mb-1">
            <span><%= number_to_currency(pool[:total_net]) %></span>
            <span><%= number_to_currency(pool[:target_amount]) %></span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2 mb-3">
            <% progress = [pool[:progress_percentage], 100].min %>
            <div class="h-2 rounded-full bg-brand" style="width: <%= [progress, 0].max %>%"></div>
          </div>
          <div class="grid grid-cols-2 gap-2 text-xs">
            <div>
              <p class="text-gray-400">Contributed</p>
              <p class="font-medium text-brand-dark"><%= number_to_currency(pool[:period_contributions]) %></p>
            </div>
            <div>
              <p class="text-gray-400">Withdrawn</p>
              <p class="font-medium text-gray-700"><%= number_to_currency(pool[:period_withdrawals]) %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
