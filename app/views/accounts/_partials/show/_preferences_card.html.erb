<%# Preferences %>
<div class="bg-white shadow-sm rounded overflow-hidden border border-gray-100 p-6">
  <h2 class="text-xl font-semibold mb-4">Preferences</h2>

  <dl class="divide-y divide-gray-200">
    <div class="py-3 flex justify-between items-center">
      <dt class="text-sm font-medium text-gray-500">
        Theme
        <span class="block text-xs font-normal text-gray-400 mt-0.5">Light or dark appearance</span>
      </dt>
      <dd>
        <%= button_to toggle_theme_account_path,
            method: :patch,
            data: { controller: "shared--toggle", action: "click->shared--toggle#toggle", shared__toggle_on_value: "translate-x-6", shared__toggle_off_value: "translate-x-1" },
            class: "relative inline-flex h-6 w-11 items-center rounded-full transition-colors #{current_user.dark? ? "bg-brand" : "bg-gray-300"}" do %>
          <span data-shared--toggle-target="thumb" class="inline-block h-4 w-4 rounded-full bg-white transition-transform <%= current_user.dark? ? "translate-x-6" : "translate-x-1" %>"></span>
        <% end %>
      </dd>
    </div>

    <div class="py-3 flex justify-between items-center">
      <dt class="text-sm font-medium text-gray-500">
        Ming Mode
        <span class="block text-xs font-normal text-gray-400 mt-0.5">Personalized UI quirks</span>
      </dt>
      <dd>
        <%= button_to toggle_ming_mode_account_path,
            method: :patch,
            data: { controller: "shared--toggle", action: "click->shared--toggle#toggle", shared__toggle_on_value: "translate-x-6", shared__toggle_off_value: "translate-x-1" },
            class: "relative inline-flex h-6 w-11 items-center rounded-full transition-colors #{current_user.ming_mode? ? "bg-brand" : "bg-gray-300"}" do %>
          <span data-shared--toggle-target="thumb" class="inline-block h-4 w-4 rounded-full bg-white transition-transform <%= current_user.ming_mode? ? "translate-x-6" : "translate-x-1" %>"></span>
        <% end %>
      </dd>
    </div>
  </dl>
</div>
