<% content_for :title, "Account" %>

<%= page_header(
    title: "Account",
    subtitle: "Your profile and app preferences",
    actions: [
      {
        label: "Edit",
        url: edit_user_registration_path,
        class: "inline-flex items-center gap-2 px-4 py-2 rounded border border-gray-300 bg-white text-gray-700 text-sm font-medium hover:bg-gray-50 shadow-sm transition"
      }
    ]
) %>

<div class="container mx-auto px-4 py-6">
  <div class="space-y-6 max-w-3xl">
    <%= render "accounts/_partials/show/info_card" %>
    <%= render "accounts/_partials/show/preferences_card" %>
  </div>
</div>
